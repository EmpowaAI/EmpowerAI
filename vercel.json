{
  "installCommand": "cd frontend && npm install --include=dev --legacy-peer-deps",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "nodeVersion": "20.x",
  "env": {
    "VITE_API_BASE_URL": "https://empowerai.onrender.com/api"
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
