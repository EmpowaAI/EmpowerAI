# Frontend API base URL (can be backend origin or include `/api`)
# Examples:
# - https://your-backend-domain          (the app will normalize to .../api)
# - https://your-backend-domain/api
VITE_API_BASE_URL=https://your-backend-domain

# Dev server proxy target (host only, no `/api`)
VITE_API_TARGET=https://your-backend-domain

# Optional legacy fallback used by some older code paths
VITE_API_URL=https://your-backend-domain

# Optional feature flags / service endpoints
VITE_USE_DEMO_MODE=false
VITE_AI_SERVICE_URL=http://127.0.0.1:8000
