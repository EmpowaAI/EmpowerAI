# Frontend Environment Variables
# Copy to `.env.local` and fill in real values.
# NEVER commit `.env.local` — it is listed in .gitignore.

# ─── Backend API ───────────────────────────────────────────────────────────────
# Full URL including /api suffix, or just the origin (the app normalises either)
VITE_API_BASE_URL=https://your-backend.onrender.com/api
VITE_API_URL=https://your-backend.onrender.com/api
VITE_API_TARGET=https://your-backend.onrender.com

# ─── Supabase (required) ───────────────────────────────────────────────────────
# These are SAFE to expose in the browser.
# ANON key: limited by Row Level Security — cannot read other users' data.
# Find both in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Feature flags ─────────────────────────────────────────────────────────────
# Set to true to use mock data instead of the real API (local UI dev only)
VITE_USE_DEMO_MODE=false

# Set to true to show the Coming Soon page and block new signups
VITE_COMING_SOON=false

# Set to true to expose the admin panel route (/dashboard/admin)
VITE_ENABLE_ADMIN=false

# NOTE: AI provider keys (Azure OpenAI etc.) must NEVER be set here.
# Any VITE_ variable is bundled into the public browser JS. All AI calls
# are routed through the backend, which holds the secrets.
