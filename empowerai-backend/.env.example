# EmpowerAI Backend Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` — it is listed in .gitignore.

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
APP_VERSION=1.0.0

# ─── Supabase (required) ───────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Encryption (required) ────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of PII (CV data, user profiles).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_char_hex_string

# ─── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=replace_if_using_ai_service_key_guard

# ─── Frontend URL (for auth redirects) ────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Email (Brevo / SendinBlue) ────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key

# ─── Payments (Paystack) ───────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public
PAYSTACK_CALLBACK_URL=https://your-domain.com/api/payments/callback
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# Paystack plan codes (create in Paystack dashboard, then paste here)
PAYSTACK_PLAN_STARTER_MONTHLY=PLN_xxxxxxxxxxxxxxx
PAYSTACK_PLAN_STARTER_ANNUAL=PLN_xxxxxxxxxxxxxxx
PAYSTACK_PLAN_PROFESSIONAL_MONTHLY=PLN_xxxxxxxxxxxxxxx
PAYSTACK_PLAN_PROFESSIONAL_ANNUAL=PLN_xxxxxxxxxxxxxxx
PAYSTACK_PLAN_ENTERPRISE_MONTHLY=PLN_xxxxxxxxxxxxxxx
PAYSTACK_PLAN_ENTERPRISE_ANNUAL=PLN_xxxxxxxxxxxxxxx

# ─── Job Aggregation APIs (optional) ──────────────────────────────────────────
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
INDEED_PUBLISHER_ID=your_indeed_publisher_id

# Job scheduler (set to false to disable; interval in minutes, min 15)
ENABLE_JOB_API_SCHEDULER=false
JOB_API_FETCH_INTERVAL=120

# ─── Redis / BullMQ queue (optional) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Rate limiting ─────────────────────────────────────────────────────────────
ENABLE_API_RATE_LIMITER=true
ENABLE_AUTH_RATE_LIMITER=true
ENABLE_AI_RATE_LIMITER=true
API_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=120
