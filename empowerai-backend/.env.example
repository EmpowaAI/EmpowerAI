# EmpowerAI Backend (example)
# Copy to `.env` and fill in real values (do not commit `.env`).

PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Services
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=replace_if_using_ai_service_key_guard

# Third-party integrations
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# Admin
ADMIN_API_KEY=replace_with_random_admin_key

# Rate limiting (set to "false" to disable a limiter)
ENABLE_API_RATE_LIMITER=true
ENABLE_AUTH_RATE_LIMITER=true
ENABLE_AI_RATE_LIMITER=true

# Tuning (defaults shown)
API_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=120

