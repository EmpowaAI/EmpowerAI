# Normalize text files to LF in the repo
* text=auto eol=lf

# Treat binary assets as binary so line-ending conversion never corrupts them.
# (A missing rule here is what destroyed frontend/public/images/empowerLogo.jpg.)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.docx  binary
*.xlsx  binary
*.zip   binary
