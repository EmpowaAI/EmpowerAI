# EmpowerAI AI Service Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` — it is listed in .gitignore.

# ─── Azure OpenAI (required) ──────────────────────────────────────────────────
# Create a resource in Azure Portal → Azure OpenAI → Keys and Endpoint
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_MODEL=gpt-4o

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Currently only "azure" is supported
AI_PRIMARY_PROVIDER=azure

# ─── Service Auth ─────────────────────────────────────────────────────────────
# A shared secret the backend sends in X-Service-Secret to authenticate
# internal service-to-service calls. Generate a random 32+ char string.
AI_SERVICE_API_KEY=replace_with_random_secret
SERVICE_SECRET=replace_with_another_random_secret

# ─── App Config ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
STRICT_REAL_DATA=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000
