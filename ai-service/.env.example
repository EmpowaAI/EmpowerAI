# EmpowerAI AI Service (example)
# Copy to `.env` and fill in real values (do not commit `.env`).

PORT=8000

# Optional: protect /api/* with an internal key
REQUIRE_AI_SERVICE_API_KEY=false
AI_SERVICE_API_KEY=replace_if_you_want_internal_auth

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com/openai/v1/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_MODEL=gpt-4o-mini

# OpenAI (if you use direct OpenAI instead of Azure)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
